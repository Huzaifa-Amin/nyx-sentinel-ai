<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>NYX SENTINEL AI — Incident {{ report_id }}</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap');
  :root{
    --bg:#060614;--bg2:#0b0b22;--card:#0f0f2a;--card2:#13133a;
    --cyan:#00d4ff;--blue:#4d9fff;--purple:#9d4eff;--green:#00e676;
    --yellow:#ffd600;--orange:#ff9100;--red:#ff1744;--pink:#f50057;
    --txt:#e8e8ff;--muted:#7777aa;--bdr:#1e1e4a;--bdr2:#2a2a5a;
    --shadow:0 4px 24px rgba(0,212,255,.08);
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--txt);font-size:13px;line-height:1.6;min-height:100vh;}

  /* ---- Animated background grid ---- */
  body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,212,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}

  /* ---- Header ---- */
  .header{position:relative;z-index:10;background:linear-gradient(135deg,rgba(6,6,20,.98),rgba(11,11,34,.98));border-bottom:1px solid var(--bdr2);padding:0 48px;display:flex;justify-content:space-between;align-items:center;height:72px;}
  .header::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);}
  .logo{display:flex;align-items:center;gap:14px;}
  .logo-icon{width:40px;height:40px;background:linear-gradient(135deg,var(--cyan),var(--blue));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;color:#000;box-shadow:0 0 20px rgba(0,212,255,.4);flex-shrink:0;}
  .logo-name{font-size:16px;font-weight:800;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;}
  .logo-sub{font-size:10px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-top:1px;}
  .header-right{display:flex;align-items:center;gap:24px;}
  .header-badge{background:rgba(255,23,68,.15);border:1px solid rgba(255,23,68,.4);color:#ff6b8a;font-size:10px;font-weight:700;padding:4px 12px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;}
  .header-meta{text-align:right;font-size:11px;color:var(--muted);line-height:1.8;}
  .header-meta strong{color:var(--txt);}

  /* ---- Severity Strip ---- */
  .sev-strip{position:relative;z-index:10;padding:14px 48px;display:flex;align-items:center;gap:20px;}
  .sev-strip.critical{background:linear-gradient(135deg,rgba(255,23,68,.18),rgba(255,23,68,.06));border-bottom:2px solid rgba(255,23,68,.5);}
  .sev-strip.high{background:linear-gradient(135deg,rgba(255,145,0,.18),rgba(255,145,0,.06));border-bottom:2px solid rgba(255,145,0,.5);}
  .sev-strip.medium{background:linear-gradient(135deg,rgba(255,214,0,.12),rgba(255,214,0,.04));border-bottom:2px solid rgba(255,214,0,.4);}
  .sev-strip.low{background:linear-gradient(135deg,rgba(0,230,118,.12),rgba(0,230,118,.04));border-bottom:2px solid rgba(0,230,118,.4);}
  .sev-strip.info{background:linear-gradient(135deg,rgba(0,212,255,.10),rgba(0,212,255,.03));border-bottom:2px solid rgba(0,212,255,.3);}
  .sev-label{font-size:11px;font-weight:700;letter-spacing:2px;padding:6px 18px;border-radius:6px;text-transform:uppercase;}
  .label-critical{background:var(--red);color:#fff;box-shadow:0 0 20px rgba(255,23,68,.5);}
  .label-high{background:var(--orange);color:#000;box-shadow:0 0 20px rgba(255,145,0,.5);}
  .label-medium{background:var(--yellow);color:#000;box-shadow:0 0 20px rgba(255,214,0,.4);}
  .label-low{background:var(--green);color:#000;box-shadow:0 0 20px rgba(0,230,118,.4);}
  .label-info{background:var(--cyan);color:#000;box-shadow:0 0 20px rgba(0,212,255,.4);}
  .score-bar-wrap{flex:1;max-width:320px;}
  .score-bar-label{font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;}
  .score-bar{height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden;}
  .score-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--blue),var(--cyan));transition:width .6s ease;width:{{ severity_score }}%;}
  .score-num{font-size:28px;font-weight:800;color:var(--cyan);line-height:1;}
  .score-denom{font-size:13px;color:var(--muted);}
  .sev-divider{width:1px;height:40px;background:var(--bdr2);}
  .sev-type-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;}
  .sev-type-val{font-size:15px;font-weight:700;}

  /* ---- Main layout ---- */
  .main{position:relative;z-index:10;max-width:1400px;margin:0 auto;padding:36px 48px;}

  /* ---- Stats Row ---- */
  .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;}
  .stat-box{background:var(--card);border:1px solid var(--bdr);border-radius:14px;padding:20px 24px;position:relative;overflow:hidden;transition:border-color .2s;}
  .stat-box:hover{border-color:var(--bdr2);}
  .stat-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--cyan),var(--blue));}
  .stat-num{font-size:38px;font-weight:900;line-height:1;display:block;margin-bottom:4px;}
  .stat-lbl{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);}
  .stat-icon{position:absolute;right:20px;top:20px;font-size:28px;opacity:.15;}
  .s-cyan{color:var(--cyan);}
  .s-red{color:var(--red);}
  .s-blue{color:var(--blue);}
  .s-green{color:var(--green);}

  /* ---- Summary ---- */
  .summary-block{background:var(--card);border:1px solid var(--bdr);border-left:3px solid var(--cyan);border-radius:14px;padding:22px 26px;margin-bottom:28px;line-height:1.8;font-size:13.5px;color:var(--txt);}
  .summary-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--cyan);margin-bottom:10px;display:flex;align-items:center;gap:8px;}

  /* ---- Section titles ---- */
  .sec-hdr{display:flex;align-items:center;gap:12px;margin:30px 0 14px;}
  .sec-hdr-line{flex:1;height:1px;background:linear-gradient(90deg,var(--bdr2),transparent);}
  .sec-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--cyan);white-space:nowrap;}
  .sec-count{background:var(--card2);border:1px solid var(--bdr);color:var(--muted);font-size:10px;font-weight:600;padding:2px 10px;border-radius:20px;}

  /* ---- Two-col ---- */
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px;}

  /* ---- Info Card ---- */
  .info-card{background:var(--card);border:1px solid var(--bdr);border-radius:14px;overflow:hidden;}
  .info-card-hdr{background:var(--card2);padding:12px 20px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--cyan);border-bottom:1px solid var(--bdr);}
  .info-card-body{padding:4px 0;}
  .kv{display:flex;padding:8px 20px;border-bottom:1px solid rgba(30,30,74,.6);}
  .kv:last-child{border-bottom:none;}
  .kv-k{width:130px;flex-shrink:0;font-size:11px;color:var(--muted);font-weight:500;}
  .kv-v{font-size:11px;color:var(--txt);word-break:break-all;font-family:'JetBrains Mono',monospace;}
  .kv-v.normal{font-family:'Inter',sans-serif;}

  /* ---- MITRE ---- */
  .mitre-card{background:var(--card);border:1px solid var(--bdr);border-radius:14px;overflow:hidden;margin-bottom:18px;}
  .mitre-body{padding:18px 20px;display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  .mitre-group-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:10px;}
  .tactic-pill{display:inline-block;background:rgba(157,78,255,.15);border:1px solid rgba(157,78,255,.4);color:#c49eff;font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;margin:3px;}
  .tech-pill{display:inline-block;background:rgba(77,159,255,.12);border:1px solid rgba(77,159,255,.4);color:var(--blue);font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;margin:3px;font-family:'JetBrains Mono',monospace;}

  /* ---- Severity Gauge ---- */
  .gauge-wrap{display:flex;align-items:center;justify-content:center;padding:10px 0;}

  /* ---- IOC Table ---- */
  .table-wrap{overflow-x:auto;margin-bottom:4px;}
  table{width:100%;border-collapse:separate;border-spacing:0;}
  thead{position:sticky;top:0;z-index:5;}
  th{background:var(--card2);color:var(--cyan);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;padding:10px 14px;text-align:left;border-bottom:1px solid var(--bdr2);white-space:nowrap;}
  th:first-child{border-radius:10px 0 0 0;}
  th:last-child{border-radius:0 10px 0 0;}
  td{padding:9px 14px;border-bottom:1px solid rgba(30,30,74,.5);font-size:11.5px;vertical-align:middle;}
  tr:last-child td{border-bottom:none;}
  tbody tr{transition:background .15s;}
  tbody tr:hover td{background:rgba(0,212,255,.04);}
  .table-card{background:var(--card);border:1px solid var(--bdr);border-radius:14px;overflow:hidden;}
  .mono{font-family:'JetBrains Mono',monospace;font-size:10.5px;}

  /* ---- IOC type pills ---- */
  .itype{display:inline-block;padding:2px 8px;border-radius:4px;font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap;font-family:'Inter',sans-serif;}
  .it-ip{background:rgba(0,212,255,.12);border:1px solid rgba(0,212,255,.3);color:var(--cyan);}
  .it-domain{background:rgba(0,230,118,.12);border:1px solid rgba(0,230,118,.3);color:var(--green);}
  .it-sha256,.it-md5,.it-sha1{background:rgba(157,78,255,.12);border:1px solid rgba(157,78,255,.3);color:#c49eff;}
  .it-url{background:rgba(255,214,0,.1);border:1px solid rgba(255,214,0,.3);color:var(--yellow);}
  .it-email{background:rgba(245,0,87,.1);border:1px solid rgba(245,0,87,.3);color:#ff6b97;}
  .it-user{background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.2);color:#88ddff;}
  .it-proc{background:rgba(255,145,0,.1);border:1px solid rgba(255,145,0,.3);color:var(--orange);}
  .it-path{background:rgba(255,145,0,.08);border:1px solid rgba(255,145,0,.2);color:#ffb74d;}
  .it-cve{background:rgba(255,214,0,.1);border:1px solid rgba(255,214,0,.25);color:#ffe066;}
  .mal-yes{color:var(--red);font-weight:700;font-size:11px;}
  .mal-no{color:var(--muted);font-size:11px;}
  .vt-bar-wrap{display:flex;align-items:center;gap:6px;}
  .vt-bar{width:48px;height:4px;background:rgba(255,255,255,.1);border-radius:2px;overflow:hidden;flex-shrink:0;}
  .vt-fill{height:100%;border-radius:2px;}
  .vt-label{font-size:10px;font-family:'JetBrains Mono',monospace;}

  /* ---- Actions ---- */
  .action-list{list-style:none;}
  .action-item{display:flex;gap:14px;padding:10px 20px;border-bottom:1px solid rgba(30,30,74,.5);align-items:flex-start;}
  .action-item:last-child{border-bottom:none;}
  .action-num{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0;background:var(--bdr2);color:var(--cyan);margin-top:1px;}
  .action-item.imm .action-num{background:rgba(255,23,68,.3);color:var(--red);border:1px solid rgba(255,23,68,.5);}
  .action-text{font-size:12.5px;line-height:1.6;}
  .action-item.imm .action-text{color:#ff6b8a;font-weight:600;}

  /* ---- Evidence ---- */
  .ev-row{padding:14px 20px;border-bottom:1px solid rgba(30,30,74,.5);}
  .ev-row:last-child{border-bottom:none;}
  .ev-name{font-size:12px;font-weight:600;margin-bottom:4px;}
  .ev-hash{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);margin-bottom:2px;}
  .ev-meta{font-size:11px;color:var(--muted);}

  /* ---- Footer ---- */
  .footer{position:relative;z-index:10;background:var(--bg2);border-top:1px solid var(--bdr);padding:16px 48px;display:flex;justify-content:space-between;align-items:center;margin-top:40px;}
  .footer-left{display:flex;flex-direction:column;gap:2px;}
  .footer-brand{font-size:13px;font-weight:700;color:var(--cyan);letter-spacing:2px;}
  .footer-sub{font-size:10px;color:var(--muted);}
  .footer-right{font-size:11px;color:var(--muted);text-align:right;}
  .conf-badge{background:rgba(255,23,68,.15);border:1px solid rgba(255,23,68,.4);color:#ff6b8a;font-size:10px;font-weight:700;padding:3px 10px;border-radius:4px;letter-spacing:1px;text-transform:uppercase;}

  /* ---- Rule groups ---- */
  .group-tag{display:inline-block;background:var(--card2);border:1px solid var(--bdr2);color:var(--muted);font-size:10px;padding:2px 8px;border-radius:4px;margin:2px;font-family:'JetBrains Mono',monospace;}
  .no-data{color:var(--muted);font-style:italic;padding:20px;text-align:center;}

  /* ---- Responsive ---- */
  @media(max-width:900px){.two-col,.stats-row{grid-template-columns:1fr;}.mitre-body{grid-template-columns:1fr;}.main{padding:20px 20px;}.header{padding:0 20px;}.footer{padding:16px 20px;flex-direction:column;gap:10px;text-align:center;}.sev-strip{padding:12px 20px;flex-wrap:wrap;gap:12px;}}
  @media print{body{background:#fff;color:#000;}.header{background:#001;}}
</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <div class="logo">
    <div class="logo-icon">N</div>
    <div>
      <div class="logo-name">NYX SENTINEL AI</div>
      <div class="logo-sub">AI-Enhanced SOC &amp; DFIR Platform</div>
    </div>
  </div>
  <div class="header-right">
    <div class="header-meta">
      <div><strong>Report ID:</strong> {{ report_id }}</div>
      <div><strong>Generated:</strong> {{ generated_at }}</div>
    </div>
    <div class="header-badge">CONFIDENTIAL</div>
  </div>
</header>

<!-- SEVERITY STRIP -->
<div class="sev-strip {{ severity_css }}">
  <span class="sev-label label-{{ severity_css }}">{{ severity_name }}</span>
  <div class="sev-divider"></div>
  <div class="score-bar-wrap">
    <div class="score-bar-label">Severity Score</div>
    <div class="score-bar"><div class="score-fill"></div></div>
  </div>
  <div>
    <span class="score-num">{{ severity_score | int }}</span>
    <span class="score-denom">/100</span>
  </div>
  <div class="sev-divider"></div>
  <div>
    <div class="sev-type-label">Incident Type</div>
    <div class="sev-type-val">{{ incident_type }}</div>
  </div>
  {% if confidence %}
  <div class="sev-divider"></div>
  <div>
    <div class="sev-type-label">Confidence</div>
    <div class="sev-type-val" style="color:var(--blue)">{{ confidence }}%</div>
  </div>
  {% endif %}
</div>

<main class="main">

  <!-- STATS -->
  <div class="stats-row">
    <div class="stat-box">
      <span class="stat-num s-cyan">{{ total_ioc_count }}</span>
      <span class="stat-lbl">IOCs Extracted</span>
      <span class="stat-icon">🔍</span>
    </div>
    <div class="stat-box">
      <span class="stat-num s-red">{{ malicious_ioc_count }}</span>
      <span class="stat-lbl">Malicious IOCs</span>
      <span class="stat-icon">☣️</span>
    </div>
    <div class="stat-box">
      <span class="stat-num" style="color:var(--orange)">{{ rule_level }}</span>
      <span class="stat-lbl">Wazuh Rule Level</span>
      <span class="stat-icon">⚡</span>
    </div>
    <div class="stat-box">
      <span class="stat-num s-blue">{{ confidence }}%</span>
      <span class="stat-lbl">Classification Confidence</span>
      <span class="stat-icon">🧠</span>
    </div>
  </div>

  <!-- SUMMARY -->
  {% if summary %}
  <div class="summary-block">
    <div class="summary-title">📋 Executive Summary</div>
    {{ summary }}
  </div>
  {% endif %}

  <!-- ALERT + ENDPOINT -->
  <div class="sec-hdr"><div class="sec-title">Incident Details</div><div class="sec-hdr-line"></div></div>
  <div class="two-col">
    <div class="info-card">
      <div class="info-card-hdr">🔔 Alert Information</div>
      <div class="info-card-body">
        <div class="kv"><span class="kv-k">Alert ID</span><span class="kv-v">{{ alert_id }}</span></div>
        <div class="kv"><span class="kv-k">Timestamp</span><span class="kv-v">{{ alert_timestamp }}</span></div>
        <div class="kv"><span class="kv-k">Rule ID</span><span class="kv-v">{{ rule_id }}</span></div>
        <div class="kv"><span class="kv-k">Rule Level</span><span class="kv-v">{{ rule_level }} / 15</span></div>
        <div class="kv"><span class="kv-k">Description</span><span class="kv-v normal">{{ rule_description }}</span></div>
        <div class="kv"><span class="kv-k">Groups</span><span class="kv-v">{% for g in rule_groups %}<span class="group-tag">{{ g }}</span>{% endfor %}</span></div>
      </div>
    </div>
    <div class="info-card">
      <div class="info-card-hdr">🖥️ Affected Endpoint</div>
      <div class="info-card-body">
        <div class="kv"><span class="kv-k">Agent Name</span><span class="kv-v">{{ agent_name }}</span></div>
        <div class="kv"><span class="kv-k">Agent ID</span><span class="kv-v">{{ agent_id }}</span></div>
        <div class="kv"><span class="kv-k">IP Address</span><span class="kv-v">{{ agent_ip }}</span></div>
        <div class="kv"><span class="kv-k">Severity</span><span class="kv-v"><span class="sev-label label-{{ severity_css }}" style="font-size:10px;padding:3px 10px">{{ severity_name }}</span></span></div>
        <div class="kv"><span class="kv-k">Incident Type</span><span class="kv-v normal">{{ incident_type }}</span></div>
        <div class="kv"><span class="kv-k">Severity Score</span><span class="kv-v">{{ severity_score | int }}/100</span></div>
      </div>
    </div>
  </div>

  <!-- MITRE -->
  {% if tactics or techniques %}
  <div class="sec-hdr"><div class="sec-title">MITRE ATT&amp;CK</div><div class="sec-hdr-line"></div></div>
  <div class="mitre-card">
    <div class="info-card-hdr">⚔️ ATT&amp;CK Framework Mapping</div>
    <div class="mitre-body">
      <div>
        <div class="mitre-group-label">Tactics</div>
        {% for t in tactics %}<span class="tactic-pill">{{ t }}</span>{% else %}<span style="color:var(--muted);font-size:12px">None identified</span>{% endfor %}
      </div>
      <div>
        <div class="mitre-group-label">Techniques</div>
        {% for t in techniques %}<span class="tech-pill">{{ t }}</span>{% else %}<span style="color:var(--muted);font-size:12px">None identified</span>{% endfor %}
      </div>
    </div>
  </div>
  {% endif %}

  <!-- IOC TABLE -->
  <div class="sec-hdr">
    <div class="sec-title">Indicators of Compromise</div>
    <div class="sec-count">{{ total_ioc_count }} total &bull; {{ malicious_ioc_count }} malicious</div>
    <div class="sec-hdr-line"></div>
  </div>
  {% if iocs %}
  <div class="table-card">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Type</th>
            <th>Value</th>
            <th>Source Field</th>
            <th>VT Detection</th>
            <th>Abuse Score</th>
            <th>Country</th>
            <th>Verdict</th>
          </tr>
        </thead>
        <tbody>
        {% for ioc in iocs %}
        <tr>
          <td>
            {% set cls = ioc.type | replace(' ','_') | lower %}
            {% if 'ip' in cls %}<span class="itype it-ip">IP Address</span>
            {% elif 'domain' in cls %}<span class="itype it-domain">Domain</span>
            {% elif 'sha256' in cls %}<span class="itype it-sha256">SHA-256</span>
            {% elif 'sha1' in cls %}<span class="itype it-sha1">SHA-1</span>
            {% elif 'md5' in cls %}<span class="itype it-md5">MD5</span>
            {% elif 'url' in cls %}<span class="itype it-url">URL</span>
            {% elif 'email' in cls %}<span class="itype it-email">Email</span>
            {% elif 'username' in cls %}<span class="itype it-user">Username</span>
            {% elif 'process' in cls %}<span class="itype it-proc">Process</span>
            {% elif 'file' in cls %}<span class="itype it-path">File Path</span>
            {% elif 'cve' in cls %}<span class="itype it-cve">CVE</span>
            {% else %}<span class="itype it-user">{{ ioc.type }}</span>{% endif %}
          </td>
          <td class="mono" style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="{{ ioc.value }}">{{ ioc.value }}</td>
          <td style="color:var(--muted);font-size:10.5px">{{ ioc.source }}</td>
          <td>
            {% if ioc.vt_malicious is not none %}
            <div class="vt-bar-wrap">
              <div class="vt-bar"><div class="vt-fill" style="width:{{ ((ioc.vt_malicious / [ioc.vt_total,1]|max)*100)|int }}%;background:{% if ioc.vt_malicious > 5 %}var(--red){% elif ioc.vt_malicious > 0 %}var(--orange){% else %}var(--green){% endif %}"></div></div>
              <span class="vt-label" style="color:{% if ioc.vt_malicious > 5 %}var(--red){% elif ioc.vt_malicious > 0 %}var(--orange){% else %}var(--green){% endif %}">{{ ioc.vt_malicious }}/{{ ioc.vt_total }}</span>
            </div>
            {% else %}<span style="color:var(--muted)">-</span>{% endif %}
          </td>
          <td>
            {% if ioc.abuse_confidence is not none %}
            <span style="font-weight:700;color:{% if ioc.abuse_confidence >= 50 %}var(--red){% elif ioc.abuse_confidence >= 25 %}var(--orange){% else %}var(--green){% endif %}">{{ ioc.abuse_confidence }}%</span>
            {% else %}<span style="color:var(--muted)">-</span>{% endif %}
          </td>
          <td style="font-size:11px;color:var(--muted)">{{ ioc.abuse_country }}</td>
          <td>
            {% if ioc.is_malicious %}
            <span class="mal-yes">⛔ MALICIOUS</span>
            {% else %}<span class="mal-no">✔ Clean</span>{% endif %}
          </td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% else %}
  <div class="table-card"><p class="no-data">No indicators of compromise extracted from this alert.</p></div>
  {% endif %}

  <!-- ACTIONS -->
  {% if actions %}
  <div class="sec-hdr"><div class="sec-title">Recommended Actions</div><div class="sec-count">{{ actions|length }} steps</div><div class="sec-hdr-line"></div></div>
  <div class="table-card">
    <ul class="action-list">
      {% for action in actions %}
      <li class="action-item {% if 'IMMEDIATE' in action %}imm{% endif %}">
        <div class="action-num">{{ loop.index }}</div>
        <div class="action-text">{{ action }}</div>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- EVIDENCE -->
  {% if evidence_files %}
  <div class="sec-hdr"><div class="sec-title">Evidence Manifest</div><div class="sec-count">{{ evidence_files|length }} files</div><div class="sec-hdr-line"></div></div>
  <div class="table-card">
    {% for f in evidence_files %}
    <div class="ev-row">
      <div class="ev-name">{{ f.file_name }}</div>
      <div class="ev-hash">SHA-256: {{ f.sha256 }}</div>
      <div class="ev-meta">{{ f.original_path }} &bull; {{ f.size_kb }} KB &bull; {{ f.collected_at }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

</main>

<footer class="footer">
  <div class="footer-left">
    <div class="footer-brand">NYX SENTINEL AI</div>
    <div class="footer-sub">AI-Enhanced SOC &amp; Digital Forensics Incident Response Platform</div>
  </div>
  <div class="footer-right">
    <div>Report {{ report_id }} &bull; {{ generated_at }}</div>
    <div style="margin-top:6px"><span class="conf-badge">Confidential</span></div>
  </div>
</footer>

</body>
</html>
